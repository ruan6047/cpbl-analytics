# --- Database ---
# 本地開發：用本 repo docker-compose 起的 PG（port 5433）
# 生產：指向主站 PostgreSQL（Docker 內網 host=postgres），schema 仍為 cpbl
DATABASE_URL=postgresql://cpbl:cpbl@localhost:5433/cpbl

# --- Ingest ---
# cpbl-opendata 原始 CSV 來源（GitHub raw）。一般不用改。
OPENDATA_BASE_URL=https://raw.githubusercontent.com/ldkrsi/cpbl-opendata/master
OPENDATA_START_YEAR=1990
OPENDATA_END_YEAR=2024

# --- ML ---
ARTIFACT_DIR=./artifacts

# --- API ---
PORT=4001
APP_VERSION=0.1.0
